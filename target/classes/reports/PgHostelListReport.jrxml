<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="PgHostelListReport"
              pageWidth="595" pageHeight="842"
              columnWidth="555"
              leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!-- Fields -->
    <field name="id" class="java.lang.Long"/>
    <field name="ownerName" class="java.lang.String"/>
    <field name="location" class="java.lang.String"/>
    <field name="rent" class="java.lang.Double"/>
    <field name="roomType" class="java.lang.String"/>

    <!-- Title -->
    <title>
        <band height="55">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="46"
                    backcolor="#1565C0" forecolor="#1565C0"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="4" width="555" height="38"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[PG Hostel List Report]]></text>
            </staticText>
        </band>
    </title>

    <!-- Header -->
    <pageHeader>
        <band height="18">

            <staticText>
                <reportElement x="0" y="0" width="277" height="18"
                    forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Online Result System]]></text>
            </staticText>

            <textField pattern="dd-MM-yyyy HH:mm">
                <reportElement x="277" y="0" width="278" height="18"
                    forecolor="#666666"/>
                <textElement textAlignment="Right"
                    verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

        </band>
    </pageHeader>

    <!-- Column Header -->
    <columnHeader>
        <band height="26">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="26"
                    backcolor="#0D2137" forecolor="#0D2137"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="0" width="30" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[#]]></text>
            </staticText>

            <staticText>
                <reportElement x="30" y="0" width="40" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>

            <staticText>
                <reportElement x="70" y="0" width="150" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Owner Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="220" y="0" width="120" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Location]]></text>
            </staticText>

            <staticText>
                <reportElement x="340" y="0" width="120" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Rent]]></text>
            </staticText>

            <staticText>
                <reportElement x="460" y="0" width="95" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Room Type]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- Detail -->
    <detail>
        <band height="22">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="22"
                    backcolor="#EEF2F7">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT}%2==0]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement x="0" y="0" width="30" height="22"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="30" y="0" width="40" height="22"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="70" y="0" width="150" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{ownerName}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="220" y="0" width="120" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{location}]]></textFieldExpression>
            </textField>

            <textField pattern="#,##0.00">
                <reportElement x="340" y="0" width="120" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{rent}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="460" y="0" width="95" height="22"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{roomType}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- Footer -->
    <pageFooter>
        <band height="20">

            <line>
                <reportElement x="0" y="0" width="555" height="1"
                    forecolor="#CCCCCC"/>
            </line>

            <staticText>
                <reportElement x="0" y="3" width="300" height="16"
                    forecolor="#888888"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Online Result System - PG Hostel List Report]]></text>
            </staticText>

            <textField>
                <reportElement x="300" y="3" width="255" height="16"
                    forecolor="#888888"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page "+$V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>

        </band>
    </pageFooter>

    <!-- Summary -->
    <summary>
        <band height="30">

            <line>
                <reportElement x="0" y="4" width="555" height="1"
                    forecolor="#CCCCCC"/>
            </line>

            <textField>
                <reportElement x="0" y="10" width="300" height="18"
                    forecolor="#1565C0"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Total PG Hostels : "+$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>